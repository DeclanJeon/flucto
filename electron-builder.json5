{
  "appId": "com.yourname.fluctoDownloader",
  "productName": "flucto-downloader",
  "directories": {
    "output": "dist",
    "buildResources": "assets"
  },
  "files": [
    "dist-electron/**/*",
    "dist/**/*",
    "!bin/*"
  ],
  "asarUnpack": [
    "bin/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  }
}
