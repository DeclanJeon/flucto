bin/ffmpeg*
bin/*.zip
bin/*.tar
bin/*.tar.xz

# ─── Environment & secrets ────────────────────────────────────────
.env
.env.local
.env.test
.env.development.local
.env.test.local
.env.production
.env.production.local

